{
  "expo": {
    "name": "47daPunjab",
    "slug": "47dapunjab",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "47dapunjab",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D7C3D"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.punjabtour.fordapunjab",
      "infoPlist": {
        "NSCameraUsageDescription": "47daPunjab needs camera access to take photos for property submissions and profile pictures.",
        "NSPhotoLibraryUsageDescription": "47daPunjab needs photo library access to upload images for property submissions, blog posts, and products.",
        "NSLocationWhenInUseUsageDescription": "47daPunjab uses your location to show nearby services and properties."
      }
    },
    "android": {
      "package": "com.punjabtour.fordapunjab",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#0D7C3D",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "INTERNET"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png",
      "name": "47daPunjab",
      "shortName": "47daPunjab",
      "description": "Your complete service platform for Punjab, Pakistan - protocol services, customs assistance, marketplace, and more.",
      "themeColor": "#0D7C3D",
      "backgroundColor": "#FFFFFF",
      "output": "single",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://47dapunjab.com"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {
        "origin": "https://47dapunjab.com"
      },
      "eas": {
        "projectId": "e47938ec-7074-40cd-a4c8-2def6ac8004c"
      }
    },
    "owner": "47dapunjab"
  }
}
